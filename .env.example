# Template do .env — copie para `.env` e preencha. O `.env` real é gitignored (NUNCA pushar).
# Usado pelo harness claude-devorq (auto-carregado por aliases.zsh com set -a).

# --- GitHub (push do repo / sync de lições DEVORQ via git) ---
GITHUB_USER=seu-usuario
GITHUB_EMAIL=voce@exemplo.com
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- DEVORQ HUB / VPS (opcional — sync de lições no PostgreSQL via SSH) ---
# Acesso real é por chave SSH em ~/.ssh; aqui só a conexão. Alternativa: ~/.devorq/config
DEVORQ_VPS_HOST=seu.vps.host
DEVORQ_VPS_PORT=22
DEVORQ_VPS_USER=root
DEVORQ_PG_DB=hermes_study
DEVORQ_PG_USER=hermes_study
DEVORQ_PG_PORT=5433
DEVORQ_PG_CONTAINER=hermesstudy_postgres
